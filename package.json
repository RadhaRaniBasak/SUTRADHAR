{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "meeting-to-action-mcp-bridge",
  "version": "0.1.0",
  "description": "Slack-triggered orchestration bridge that extracts action items from thread context and dispatches them to Jira, Linear, GitHub, and Notion via the Model Context Protocol.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "worker": "tsx watch src/queue/eventWorker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "mcp:server": "tsx src/services/mcp/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "@notionhq/client": "^2.2.15",
    "@octokit/auth-app": "^7.1.5",
    "@octokit/request-error": "^6.1.8",
    "@octokit/rest": "^21.0.2",
    "@slack/bolt": "^4.1.0",
    "@slack/types": "^2.21.0",
    "@slack/web-api": "^7.7.0",
    "axios": "^1.7.9",
    "bullmq": "^5.34.10",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.1",
    "graphql-request": "^7.1.2",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
